// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum UnidadTipo {
  DEPARTAMENTO
  LOCAL
  COCHERA
  BAULERA
  OTRO
}

enum PersonaTipo {
  PROPIETARIO
  INQUILINO
  OTRO
}

enum ExpensaEstado {
  PENDIENTE
  PARCIAL
  PAGADO
}

enum MedioPago {
  EFECTIVO
  TRANSFERENCIA
  DEBITO
  CREDITO
  MERCADOPAGO
  OTRO
}

model Consorcio {
  id           Int           @id @default(autoincrement())
  nombre       String
  direccion    String

  // opcionales (te sirven para producción real)
  ciudad       String?
  provincia    String?
  codigoPostal String?
  cuit         String?
  fechaCreacion DateTime     @default(now())

  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  unidades     Unidad[]
  liquidaciones Liquidacion[]

  @@index([nombre])
}

model Unidad {
  id             Int          @id @default(autoincrement())
  consorcioId    Int
  identificador  String       // ej: "1A", "PB Local", "Cochera 3"
  tipo           UnidadTipo   @default(DEPARTAMENTO)
  piso           String?      // string para soportar "PB", "SS", "1", "2", etc.
  superficie     Float?
  porcentajeExpensas Float?   // ej: 12.34 (validar en app: suma 100)

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  consorcio      Consorcio    @relation(fields: [consorcioId], references: [id], onDelete: Cascade)
  personas       UnidadPersona[]
  expensas       Expensa[]

  @@unique([consorcioId, identificador])
  @@index([consorcioId])
}

model Persona {
  id         Int          @id @default(autoincrement())
  nombre     String
  apellido   String
  email      String?
  telefono   String?
  tipo       PersonaTipo  @default(PROPIETARIO)

  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  unidades   UnidadPersona[]

  @@index([apellido, nombre])
  @@index([email])
}

model UnidadPersona {
  // tabla puente N:N Persona <-> Unidad
  unidadId   Int
  personaId  Int

  // opcionales útiles en consorcios reales
  desde      DateTime?
  hasta      DateTime?
  esTitular  Boolean    @default(true)

  unidad     Unidad     @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  persona    Persona    @relation(fields: [personaId], references: [id], onDelete: Cascade)

  @@id([unidadId, personaId])
  @@index([personaId])
}

model Liquidacion {
  id            Int       @id @default(autoincrement())
  consorcioId   Int
  // Guardamos "YYYY-MM" como string por simplicidad (SQLite friendly)
  periodo       String    // ej: "2026-03"
  fechaEmision  DateTime  @default(now())
  fechaVencimiento DateTime?
  total         Float?    // se puede recalcular desde Expensa, pero queda cómodo guardarlo

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  consorcio     Consorcio @relation(fields: [consorcioId], references: [id], onDelete: Cascade)
  expensas      Expensa[]

  @@unique([consorcioId, periodo])
  @@index([consorcioId])
}

model Expensa {
  id           Int          @id @default(autoincrement())
  liquidacionId Int
  unidadId     Int

  monto        Float
  saldo        Float
  estado       ExpensaEstado @default(PENDIENTE)

  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  liquidacion  Liquidacion  @relation(fields: [liquidacionId], references: [id], onDelete: Cascade)
  unidad       Unidad       @relation(fields: [unidadId], references: [id], onDelete: Cascade)
  pagos        Pago[]

  @@unique([liquidacionId, unidadId])
  @@index([unidadId])
  @@index([liquidacionId])
}

model Pago {
  id         Int       @id @default(autoincrement())
  expensaId  Int

  fechaPago  DateTime  @default(now())
  monto      Float
  medioPago  MedioPago @default(TRANSFERENCIA)
  referencia String?   // nro comprobante/CBU/ID mp/etc.
  nota       String?

  createdAt  DateTime  @default(now())

  expensa    Expensa   @relation(fields: [expensaId], references: [id], onDelete: Cascade)

  @@index([expensaId])
  @@index([fechaPago])
}
